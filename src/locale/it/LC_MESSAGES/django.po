msgid ""
"Your password must be at least %(min_length)d characters long, contain at "
"least one uppercase letter, one lowercase letter, one digit, and one special "
"character (!@#$%%^&*(),.?\":{}|<>)."
msgstr ""
"La tua password deve contenere almeno %(min_length)d caratteri e includere "
"almeno una lettera maiuscola, una lettera minuscola, una cifra e un "
"carattere speciale (!@#$%%^&*(),.?\":{}|<>)."


#, python-format
msgid "Password must be at least %(min_length)d characters long."
msgstr "La password deve contenere almeno %(min_length)d caratteri."

msgid "Password must contain at least one uppercase letter."
msgstr "La password deve contenere almeno una lettera maiuscola."

msgid "Password must contain at least one lowercase letter."
msgstr "La password deve contenere almeno una lettera minuscola."

msgid "Password must contain at least one digit."
msgstr "La password deve contenere almeno una cifra."

msgid ""
"Password must contain at least one special character (!@#$%^&*(),.?\":{}|<>)"
"[]=."
msgstr ""
"La password deve contenere almeno un carattere speciale (!@#$%^&*(),.?\":{}|"
"<>)[]=."

